{
  "permissions": {
    "allow": [
      "Bash",
      "WebSearch",
      "WebFetch",
      "PowerShell",
      "Skill(remember)",
      "Skill(schedule)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "default"
  },
  "model": "opus",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -File C:/Users/Michael/.claude/telemetry/log-prompt.ps1",
            "shell": "bash"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -File C:/Users/Michael/.claude/telemetry/analyze-session.ps1",
            "shell": "bash"
          },
          {
            "type": "command",
            "command": "printf '\\a'",
            "shell": "bash"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -File C:/Users/Michael/.claude/telemetry/log-tool-done.ps1",
            "shell": "bash",
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -File C:/Users/Michael/.claude/telemetry/record-compact.ps1",
            "shell": "bash",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -File C:/Users/Michael/.claude/telemetry/log-permission.ps1",
            "shell": "bash",
            "async": true
          },
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -Command \"(New-Object System.Media.SoundPlayer 'C:/Users/Michael/.claude/sounds/ding-half.wav').PlaySync()\"",
            "shell": "bash",
            "async": true
          },
          {
            "type": "command",
            "command": "printf '\\a'",
            "shell": "bash",
            "async": true
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "enableWorkflows": true,
  "statusLine": {
    "type": "command",
    "command": "powershell.exe -NoProfile -File C:/Users/Michael/.claude/statusline.ps1",
    "padding": 1
  },
  "enabledPlugins": {
    "supabase@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "remember@claude-plugins-official": true,
    "notion@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark-daltonized",
  "editorMode": "normal",
  "preferredNotifChannel": "auto",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}
